# ClickUp (local main.py / proxy / discovery — worker loads tasks from Supabase Task / TaskSession)
CLICKUP_TOKEN=
# Team + assignee id: required for Trace proxy /clickup/tasks (all open assignee tasks, paginated).
# Team id: workspace URL or Settings → copy id. Assignee: your numeric user id (e.g. from API or profile URL).
CLICKUP_TEAM_ID=9016313867
CLICKUP_ASSIGNEE_ID=100975806
# Optional: limit proxy list to these statuses (comma-separated, exact ClickUp names). Empty = every non-closed task assigned to you.
# CLICKUP_PROXY_STATUSES=in progress,open
# Optional: defaults to config.USER_EMAIL (pipeline main.py)
# CLICKUP_USER_EMAIL=
# Delivery → VAV Internal → Calls (run: python -m integrations.clickup.discovery --show-tasks)
# CLICKUP_CALLS_LIST_ID=

# Google Calendar OAuth (gcal/client.py) — default redirect http://localhost:8080/
# If using a "Web application" OAuth client, add that URI under Authorized redirect URIs.
# If Google shows "access_denied" / verification: OAuth consent screen → Test users → add this Gmail.
# GCAL_OAUTH_PORT=8080
# If browser → localhost callback fails, use manual code paste:
# GCAL_OAUTH_CONSOLE=1
